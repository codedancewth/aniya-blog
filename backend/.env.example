# 服务器配置
SERVER_PORT=8080
SERVER_MODE=debug

# 数据库配置
# SQLite 配置
DB_DRIVER=sqlite
DB_SOURCE=data/aniya.db

# MySQL 配置 (取消注释并使用 MySQL 时，请注释掉上面的 SQLite 配置)
# DB_DRIVER=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=aniya_blog
# DB_USERNAME=root
# DB_PASSWORD=your_password
# DB_SOURCE=  # 留空则自动从上述配置构建 DSN，或手动填写完整 DSN

# JWT 配置
JWT_SECRET=aniya-blog-secret-key-change-in-production-$(date +%s)
JWT_EXPIRE_TIME=24h

# CORS 配置
ALLOW_ORIGIN=http://localhost:4321,http://127.0.0.1:4321

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/server.log
