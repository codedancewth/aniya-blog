---
// GitHub 最近提交记录组件
const GITHUB_USERNAME = 'codedancewth'
const GITHUB_API = `https://api.github.com/users/${GITHUB_USERNAME}/events`

interface GitHubEvent {
  type: string
  repo: {
    name: string
  }
  created_at: string
  payload?: {
    commits?: Array<{
      sha: string
      message: string
    }>
    size?: number
  }
}

async function fetchGitHubEvents() {
  try {
    const response = await fetch(GITHUB_API, {
      headers: {
        'Accept': 'application/vnd.github.v3+json',
      },
    })
    const data = await response.json()
    return data.filter((event: GitHubEvent) => event.type === 'PushEvent').slice(0, 2)
  } catch (error) {
    console.error('Error fetching GitHub events:', error)
    return []
  }
}

const events = await fetchGitHubEvents()
---

<div class="rounded-xl border p-4">
  <div class="mb-4 flex items-center gap-2">
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
    </svg>
    <h3 class="text-lg font-medium">GitHub Activity</h3>
  </div>
  
  {events.length > 0 ? (
    <div class="space-y-3">
      {events.map((event: GitHubEvent) => (
        <div class="flex items-start gap-3">
          <div class="mt-1 h-2 w-2 flex-shrink-0 rounded-full bg-green-500"></div>
          <div class="flex-1">
            <a 
              href={`https://github.com/${event.repo.name}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-foreground hover:text-primary"
            >
              {event.repo.name}
            </a>
            {event.payload?.commits && event.payload.commits.length > 0 && (
              <p class="text-xs text-muted-foreground mt-0.5">
                {event.payload.commits[0].message}
              </p>
            )}
            <p class="text-xs text-muted-foreground">
              {new Date(event.created_at).toLocaleDateString('zh-CN', {
                month: 'short',
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
              })}
            </p>
          </div>
        </div>
      ))}
    </div>
  ) : (
    <p class="text-sm text-muted-foreground">暂无最近提交记录</p>
  )}
  
  <div class="mt-4 pt-3 border-t">
    <a 
      href={`https://github.com/${GITHUB_USERNAME}`}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs text-muted-foreground hover:text-primary transition-colors"
    >
      查看更多 →
    </a>
  </div>
</div>
