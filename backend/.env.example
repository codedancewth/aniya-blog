# 服务器配置
SERVER_PORT=8080
SERVER_MODE=debug

# 数据库配置
DB_DRIVER=sqlite
DB_SOURCE=data/aniya.db

# JWT 配置
JWT_SECRET=aniya-blog-secret-key-change-in-production-$(date +%s)
JWT_EXPIRE_TIME=24h

# CORS 配置
ALLOW_ORIGIN=http://localhost:4321,http://127.0.0.1:4321

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/server.log
