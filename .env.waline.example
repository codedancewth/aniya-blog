# Waline 本地部署环境变量配置
# 复制此文件为 .env.waline 并修改相应配置

# ============ 站点配置 ============
SITE_NAME=wth2jhl.online
SITE_URL=https://wth2jhl.online

# ============ MySQL 数据库配置 ============
# 数据库连接信息
MYSQL_HOST=waline-db
MYSQL_PORT=3306
MYSQL_DB=waline
MYSQL_USER=waline
MYSQL_PASSWORD=WalineUser@2026

# MySQL root 密码（仅首次初始化需要）
MYSQL_ROOT_PASSWORD=WalineRoot@2026

# ============ Waline 服务端配置 ============
# 服务端口
PORT=8383

# 管理员令牌（用于后台管理）
TOKEN=WalineSecureToken2026ChangeMe

# 安全选项
SECURE=true

# ============ 评论限制 ============
# 每用户每分钟评论数限制
LIMIT_PER_MINUTE=10

# 总评论数限制
LIMIT_ALL=100

# ============ 邮件通知（可选） ============
# 取消注释并配置以启用邮件通知
# MAIL_USER=your-email@example.com
# SMTP_SERVICE=Gmail
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-smtp-password

# ============ 其他配置 ============
# 地区
REGION=CN

# 语言
LANGUAGE=zh-CN

# ============ Docker 端口映射 ============
# MySQL 外部访问端口（避免与博客 MySQL 冲突）
MYSQL_EXTERNAL_PORT=3307

# Waline 服务外部访问端口
WALINE_EXTERNAL_PORT=8383
