---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  { depth: 2, slug: 'gossips', text: 'Gossips' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings}>
  <p>开发者 / 技术博主</p>
  <p>
    欢迎来到 <strong>wth2jhl.online</strong>！这是一个专注于技术分享、学习记录和个人项目展示的博客平台。
  </p>
  <p>
    <strong>Motto:</strong> Stay hungry, Stay foolish.
  </p>
  <p>
    在这里，你可以找到关于 Google Play 支付、技术架构、开发实践等方面的深度文章。所有技术内容都来自实际项目经验，力求为开发者提供有价值的参考。
  </p>
  <Button title='Sponsor Me' class='w-fit' href='/projects#sponsorship' variant='ahead' />

  {/* general-talk */}
  <h2 id='hobbies'>关于我</h2>
  <ul>
    <li>👨‍💻 <strong>全栈开发者</strong> - 专注于 Web 开发和移动应用开发</li>
    <li>📱 <strong>Google Play 开发者</strong> - 分享 Google Play 支付和上架实战经验</li>
    <li>✍️ <strong>技术博主</strong> - 记录技术学习心得和项目实践</li>
    <li>🎯 <strong>开源贡献者</strong> - Astro Theme Pure 主题作者</li>
  </ul>

  {/* tools */}
  <h2 id='tools'>技术栈</h2>
  <p>日常开发和使用的工具/技术：</p>
  <ToolSection
    class='mb-5'
    title='前端开发'
    tools={[
      {
        name: 'Astro',
        description: '静态站点生成器',
        href: 'https://astro.build/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'React',
        description: '前端框架',
        href: 'https://react.dev/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'TypeScript',
        description: '类型化 JavaScript',
        href: 'https://www.typescriptlang.org/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'Tailwind CSS',
        description: 'CSS 框架',
        href: 'https://tailwindcss.com/',
        icon: import('@/assets/tools/chrome.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='后端开发'
    tools={[
      {
        name: 'Go',
        description: '后端语言',
        href: 'https://go.dev/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Node.js',
        description: '运行时环境',
        href: 'https://nodejs.org/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'MySQL',
        description: '关系型数据库',
        href: 'https://www.mysql.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Gin',
        description: 'Go Web 框架',
        href: 'https://gin-gonic.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='开发工具'
    tools={[
      {
        name: 'VS Code',
        description: '代码编辑器',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Git',
        description: '版本控制',
        href: 'https://git-scm.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Docker',
        description: '容器化',
        href: 'https://www.docker.com/',
        icon: import('@/assets/tools/ubuntu.svg?raw')
      },
      {
        name: 'Postman',
        description: 'API 测试',
        href: 'https://www.postman.com/',
        icon: import('@/assets/tools/chrome.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>社交网络</h2>
  <p>关注我，获取最新动态：</p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/codedancewth',
        text: 'followers',
        api: 'github/codedancewth'
      },
      {
        platform: 'Blog',
        icon: 'rss',
        color: '#f26522',
        link: 'https://wth2jhl.online/rss.xml',
        text: 'RSS 订阅'
      }
    ]}
  />

  {/* gossips */}
  <h2 id='gossips'>博客统计</h2>
  <Collapse title='📊 本站数据'>
    博客使用 Astro 框架构建，部署在 Vercel 上。所有文章均为原创或翻译，旨在分享技术经验和学习心得。
    如有任何问题或建议，欢迎通过 GitHub 联系。
  </Collapse>

  {/* about-blog */}
  <h2 id='about-blog'>关于博客</h2>
  <p>博客发展历程：</p>
  <Timeline
    events={[
      {
        date: '2026-03-26',
        content:
          '博客完成评论系统迁移，使用 Go 后端 + MySQL 存储评论数据'
      },
      {
        date: '2026-03-25',
        content:
          '博客部署上线，使用 Astro + Astro Theme Pure 主题'
      },
      {
        date: '2024-07-26',
        content:
          'Astro Theme Pure 主题发布到 <a href="https://github.com/cworld1/astro-theme-pure" target="_blank">GitHub</a>'
      }
    ]}
  />
  <p>
    博客的技术栈和依赖：
  </p>
  <ul>
    <li><strong>框架 & 主题:</strong> <a href='https://astro.build/' target='_blank'>Astro</a> + <a
        href='https://github.com/cworld1/astro-theme-pure'
        target='_blank'>Astro Theme Pure</a
      >
    </li>
    <li>
      <strong>部署平台:</strong> <a href='https://vercel.com/' target='_blank'>Vercel</a>
    </li>
    <li>
      <strong>后端服务:</strong> Go + Gin + MySQL
    </li>
    <li>
      <strong>评论系统:</strong> 自研 Go 后端评论 API
    </li>
    <li>
      <strong>代码托管:</strong> <a href='https://github.com/codedancewth/aniya-blog' target='_blank'>GitHub</a>
    </li>
  </ul>
</PageLayout>
